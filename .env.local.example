# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (Project Settings -> API -> service_role). Server-only —
# never prefix with NEXT_PUBLIC_. Used by app/api/staff/create to provision
# staff logins without signing out the admin who's creating them.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Set to "true" to enable the public /setup wizard (self-service org creation).
# Leave unset/false in production until there's a real gate (invite tokens,
# manual provisioning, etc.) in front of it — otherwise anyone with the URL
# can create an org. This only hides the page UI; the actual hard boundary
# is the "Allow new users to sign up" toggle in Supabase Auth settings.
NEXT_PUBLIC_SETUP_ENABLED=false
